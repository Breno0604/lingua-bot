# ──────────────────────────────────────────────
# LinguaBot --- Configuracao de Ambiente
# ──────────────────────────────────────────────
# Copie este arquivo para .env e preencha os valores.
# cp .env.example .env

# --- Telegram (obrigatorio - criar via @BotFather) ---
BOT_TOKEN=seu_token_aqui

# --- Groq API (obrigatorio - https://console.groq.com/keys) ---
GROQ_API_KEY=gsk_sua_chave_groq_aqui

# --- Moder de Operacao ---
# polling para dev local, webhook para producao Render
BOT_MODE=polling

# --- Render (obrigatorio apenas em modo webhook) ---
RENDER_URL=https://seu-app.onrender.com

# --- Modelo Groq (opcional) ---
GROQ_MODEL=llama-3.3-70b-versatile

# --- Supabase (opcional - producao PostgreSQL) ---
SUPABASE_URL=
SUPABASE_KEY=

# --- Deepgram (opcional, pos-MVP) ---
DEEPGRAM_API_KEY=

# --- ElevenLabs (opcional, pos-MVP) ---
ELEVENLABS_API_KEY=

# --- Configuracoes opcionais (com defaults) ---
DAILY_LIMIT=100
MAX_HISTORY_TURNS=15
